# App
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/dbname"

# Redis (self-hosted)
REDIS_URL="redis://localhost:6379"

# Better Auth
BETTER_AUTH_SECRET=""   # min 32 chars — generate with: openssl rand -base64 32
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Corsair — generate with: openssl rand -base64 32
CORSAIR_KEK=""

# AI
OPENAI_API_KEY=""
GOOGLE_GENERATIVE_AI_API_KEY="" 

# Gmail
GMAIL_PUBSUB_TOPIC=""
GMAIL_WEBHOOK_SECRET=""   # optional

# Inngest (required in development)
INNGEST_DEV="1"

# Inngest (required in production only)
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
